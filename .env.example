# OverseaArk local operations configuration.
# Target deployment defaults: Ubuntu 24.04 aarch64 DGX Spark CUDA 13.

OVERSEAARK_ROOT=/home/Developer/overseaark
OVERSEAARK_MODELS_DIR=/home/Developer/overseaark-models
OVERSEAARK_DATA_DIR=/home/Developer/overseaark-data
OVERSEAARK_LOG_DIR=/home/Developer/overseaark-data/logs
OVERSEAARK_PID_DIR=/home/Developer/overseaark-data/run

# Runtime must stay local-only unless explicitly changed by an operator.
OVERSEAARK_HOST=127.0.0.1
OVERSEAARK_BACKEND_PORT=8000
OVERSEAARK_FRONTEND_PORT=3000

# Development controls.
OVERSEAARK_SKIP_MODELS=0
OVERSEAARK_MOCK_MODE=0
OVERSEAARK_ENABLE_NETWORK_BOOTSTRAP=1
OVERSEAARK_SYNC_OPTIONAL_MODELS=0
OVERSEAARK_ADAPTER_MODE=command
OVERSEAARK_ALLOW_DEGRADED_VIDEO=1
OVERSEAARK_ADAPTER_TIMEOUT=1200

# Optional overrides; the launcher supplies pinned local defaults when omitted.
# OVERSEAARK_LLAMA_CLI=/root/llama.cpp/build/bin/llama-cli
# OVERSEAARK_LLM_TOKENS=512
# OVERSEAARK_LLM_CONTEXT=2048
# OVERSEAARK_LLM_BATCH=256
# OVERSEAARK_LLM_UBATCH=128
# OVERSEAARK_BENCH_TIMEOUT=1200

# Mirrors. ModelScope is used first for StepFun/Cosmos model families.
MODELSCOPE_ENDPOINT=https://modelscope.cn
HF_ENDPOINT=https://hf-mirror.com

# Offline runtime defaults used by start/restart and benchmark commands.
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1
HF_DATASETS_OFFLINE=1
NO_PROXY=127.0.0.1,localhost
no_proxy=127.0.0.1,localhost
