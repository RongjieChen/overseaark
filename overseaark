#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'USAGE'
OverseaArk operations dispatcher

Usage:
  ./overseaark <command> [args]

Commands:
  bootstrap             Create local envs, install app dependencies, optionally fetch models
  start                 Bootstrap/repair as needed, then start and health-check the app
  stop                  Stop managed processes
  restart               Stop then start
  status                Show process, path, and model status
  logs [backend|frontend|llm|all]
                        Tail service logs
  llm start|stop|status Manage the on-demand local vLLM process
  doctor                Run non-destructive environment checks
  models verify         Verify model manifest and checksums
  models sync           Fetch model snapshots into the local model cache
  benchmark llm|image|audio|video
                        Run local benchmark smoke for one modality
  test                  Run local-safe smoke tests for dispatcher and scripts
  help                  Show this help

Environment:
  Copy .env.example to .env and adjust paths or ports.
  Set OVERSEAARK_SKIP_MODELS=1 to skip model download/strict model presence checks.
  Set OVERSEAARK_MOCK_MODE=1 for local developer smoke runs without GPU/model assets.
  Set OVERSEAARK_AUTO_BOOTSTRAP=0 or OVERSEAARK_AUTO_DOWNLOAD_MODELS=0 for strict fail-fast startup.
USAGE
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  bootstrap|start|stop|restart|status|doctor|test)
    exec bash "$ROOT_DIR/scripts/${cmd}.sh" "$@"
    ;;
  logs)
    exec bash "$ROOT_DIR/scripts/lifecycle.sh" logs "$@"
    ;;
  llm)
    exec bash "$ROOT_DIR/scripts/lifecycle.sh" llm "${1:-status}"
    ;;
  models)
    sub="${1:-verify}"
    shift || true
    exec bash "$ROOT_DIR/scripts/models.sh" "$sub" "$@"
    ;;
  benchmark)
    exec bash "$ROOT_DIR/scripts/benchmark.sh" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 64
    ;;
esac
